{
  "name": "katagami-cli",
  "version": "0.1.0",
  "description": "Contribute to the Katagami design commons from any terminal: login, pull, remix, submit.",
  "type": "module",
  "bin": {
    "katagami": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arni-labs/katagami"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  }
}
