<?xml version="1.0" encoding="utf-8"?>
<!-- Katagami Design Language Commons — Core Data Model
     Five entity types: DesignLanguage, DesignElement, DesignSource, ElementManifest, Taxonomy.
     All large content stored in paw-fs Files; entities hold metadata and JSON specs. -->
<edmx:Edmx Version="4.0" xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx">
  <edmx:DataServices>
    <Schema Namespace="Katagami" xmlns="http://docs.oasis-open.org/odata/ns/edm">

      <!-- DesignLanguage: complete design language with structured spec + embodiment -->
      <EntityType Name="DesignLanguage">
        <Key>
          <PropertyRef Name="Id" />
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false" />
        <Property Name="State" Type="Edm.String" Nullable="false" DefaultValue="Draft" />
        <Property Name="Name" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Slug" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Version" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <!-- Structured spec sections (JSON) -->
        <Property Name="Philosophy" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Tokens" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Rules" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="LayoutPrinciples" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Guidance" Type="Edm.String" Nullable="false" DefaultValue="" />
        <!-- Imagery & generative direction (JSON) -->
        <Property Name="ImageryDirection" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="GenerativeCanvas" Type="Edm.String" Nullable="false" DefaultValue="" />
        <!-- DESIGN.md: generated portable agent handoff artifact -->
        <Property Name="DesignMdFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="DesignMdAssetId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="DesignMdAssetUrl" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="DesignMdLintResult" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="DesignMdFormatVersion" Type="Edm.String" Nullable="false" DefaultValue="alpha" />
        <!-- shadcn/ui: generated registry theme projection for component-first apps -->
        <Property Name="ShadcnExportFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="ShadcnExportFormatVersion" Type="Edm.String" Nullable="false" DefaultValue="registry-theme-v1" />
        <Property Name="ShadcnExportManifest" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="HasShadcnExport" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <!-- shadcn/ui: first-class agent-authored component recipes and preview-shot manifests -->
        <Property Name="ShadcnComponentSpecFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="ShadcnComponentSpecFormatVersion" Type="Edm.String" Nullable="false" DefaultValue="component-recipes-v1" />
        <Property Name="ShadcnComponentSpecManifest" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="HasShadcnComponentSpec" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="ShadcnPreviewShotsFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="ShadcnPreviewShotsFormatVersion" Type="Edm.String" Nullable="false" DefaultValue="preview-shots-v1" />
        <Property Name="ShadcnPreviewShotsManifest" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="HasShadcnPreviewShots" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <!-- Embodiment: self-contained HTML file in paw-fs -->
        <Property Name="EmbodimentFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="EmbodimentAssetId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="EmbodimentAssetUrl" Type="Edm.String" Nullable="false" DefaultValue="" />
        <!-- Composition embodiments: bespoke Landing + Dashboard screens (HTML), tokenized for remix. Gated like the embodiment. -->
        <Property Name="LandingFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="DashboardFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="HasCompositions" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="ThumbnailFileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="ThumbnailAssetId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="ThumbnailAssetUrl" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="HasThumbnail" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="HasPublishedAssets" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="ElementCount" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <Property Name="CompositionCount" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <!-- Lineage -->
        <Property Name="ParentIds" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="LineageType" Type="Edm.String" Nullable="false" DefaultValue="original" />
        <Property Name="GenerationNumber" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <!-- Classification -->
        <Property Name="TaxonomyIds" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="Tags" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="SourceIds" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="Credits" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="HasCredits" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="ModelProvenance" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="HasModelProvenance" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <!-- Provenance tier (ADR-0016): WHO did the creative work — agent_generated | human_curated | human_authored -->
        <Property Name="ProvenanceTier" Type="Edm.String" Nullable="false" DefaultValue="agent_generated" />
        <Property Name="Provenance" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="HasProvenance" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <!-- Taste embedding: semantic vector for discovery (taste deck,
             related languages). JSON float array + the model that made it. -->
        <Property Name="TasteVector" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="TasteVectorModel" Type="Edm.String" Nullable="false" DefaultValue="" />
        <!-- Precomputed gallery facets: flat scalars for server-side filtering +
             keyset pagination. The kernel can only $filter stored scalars (not
             JSON-derived values, and only case-sensitively), so the categorical
             facets are derived once at publish and stored here. Written by the
             curation finalizer / backfill via AttachComputedFacets. -->
        <Property Name="SearchBlob" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="HueBucket" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="FamilyId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <!-- Quality signals -->
        <Property Name="QualityScore" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="QualityReviewPassed" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="ForkCount" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <Property Name="UsageCount" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <Property Name="CuratorNotes" Type="Edm.String" Nullable="false" DefaultValue="" />
        <!-- Gallery display -->
        <Property Name="Featured" Type="Edm.Boolean" Nullable="false" DefaultValue="false" />
        <Property Name="DisplayOrder" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <!-- Timestamps -->
        <Property Name="CreatorSub" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="CreatorEmail" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="CreatorName" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" />
        <Property Name="UpdatedAt" Type="Edm.DateTimeOffset" />
        <Property Name="PublishedAt" Type="Edm.DateTimeOffset" />
      </EntityType>

      <!-- DesignElement: one canonical element within one DesignLanguage -->
      <EntityType Name="DesignElement">
        <Key>
          <PropertyRef Name="Id" />
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false" />
        <Property Name="State" Type="Edm.String" Nullable="false" DefaultValue="Pending" />
        <Property Name="DesignLanguageId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="ElementKey" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Category" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Name" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="HtmlSnippet" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="VerificationNotes" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" />
        <Property Name="UpdatedAt" Type="Edm.DateTimeOffset" />
      </EntityType>

      <!-- DesignSource: raw research material (articles, style guides, etc.) -->
      <EntityType Name="DesignSource">
        <Key>
          <PropertyRef Name="Id" />
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false" />
        <Property Name="State" Type="Edm.String" Nullable="false" DefaultValue="Submitted" />
        <Property Name="Title" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="SourceType" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="SourceUrl" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="FileId" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="Metadata" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="ExtractedTopics" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="DerivedLanguageIds" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="ErrorMessage" Type="Edm.String" Nullable="false" DefaultValue="" />
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" />
        <Property Name="UpdatedAt" Type="Edm.DateTimeOffset" />
      </EntityType>

      <!-- ElementManifest: the canonical set of UI elements every design language must render -->
      <EntityType Name="ElementManifest">
        <Key>
          <PropertyRef Name="Id" />
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false" />
        <Property Name="State" Type="Edm.String" Nullable="false" DefaultValue="Draft" />
        <Property Name="Version" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <Property Name="Elements" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="Compositions" Type="Edm.String" Nullable="false" DefaultValue="[]" />
        <Property Name="ElementCount" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <Property Name="CompositionCount" Type="Edm.Int32" Nullable="false" DefaultValue="0" />
        <Property Name="CreatedAt" Type="Edm.DateTimeOffset" />
        <Property Name="UpdatedAt" Type="Edm.DateTimeOffset" />
      </EntityType>

      <!-- Taxonomy: agent-maintained hierarchical classification of design movements -->
      <EntityType Name="Taxonomy">
        <Key>
          <PropertyRef Name="Id" />
        </Key>
        <Property Name="Id" Type="Edm.Guid" Nullable="false" />
