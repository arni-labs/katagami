        <Property Name="Mood" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="Ramps" Type="Edm.String" Nullable="false" DefaultValue="{}" />
        <Property Name="ProofScenes" Type="Edm.String" Nullable="false" DefaultValue="[]" />
